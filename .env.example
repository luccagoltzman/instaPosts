# Desenvolvimento local: chave exposta no frontend (só use em .env, nunca commite)
# Obtenha em: https://rapidapi.com → API "Instagram120"
VITE_RAPIDAPI_KEY=

# Host da API (opcional; padrão: instagram120.p.rapidapi.com)
# VITE_RAPIDAPI_HOST=instagram120.p.rapidapi.com

# Produção (Vercel): configure RAPIDAPI_KEY nas Environment Variables do projeto.
# A chave fica apenas no servidor (proxy em /api/instagram/*).

